<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- The PyInstaller bootloader unpacks and executes code at runtime, so under
       the hardened runtime (required for notarization) it needs these exceptions.
       Bluetooth itself is governed by TCC: when run from a terminal, macOS prompts
       for the terminal's Bluetooth access on first use — no sandbox entitlement is
       required for a non-sandboxed Developer ID command-line tool. -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
</dict>
</plist>
